# Supabase Configuration
# Get these values from: https://app.supabase.com/project/_/settings/api

# Your Supabase project URL (e.g., https://abcdefghijklmnop.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anon/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (Required for server-side admin operations)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Your application URL (for OAuth redirects)
# Development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Production (uncomment and update when deploying)
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Gemini API Key (for AI features)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_PRO_YEARLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_TEAMS_MONTHLY=price_...
